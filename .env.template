# ==========================================
# SekaiLink Environment Variables Template
# ==========================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ------------------------------------------
# Flask Configuration
# ------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-super-secret-flask-key-here-generate-a-random-string

# Environment: development, production, testing
FLASK_ENV=development

# Enable/disable debug mode (NEVER enable in production!)
FLASK_DEBUG=True

# ------------------------------------------
# PostgreSQL Database
# ------------------------------------------
# Database connection settings
POSTGRES_HOST=sekailink_db
POSTGRES_PORT=5432
POSTGRES_DB=sekailink
POSTGRES_USER=sekailink_user
POSTGRES_PASSWORD=your-secure-database-password-here

# Full database URL (auto-constructed, or override)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ------------------------------------------
# Redis Configuration
# ------------------------------------------
# Redis connection for Celery and caching
REDIS_HOST=sekailink_redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# ------------------------------------------
# Celery Configuration
# ------------------------------------------
# Celery broker and result backend
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ------------------------------------------
# Discord OAuth2
# ------------------------------------------
# Create Discord application at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id-here
DISCORD_CLIENT_SECRET=your-discord-client-secret-here
DISCORD_REDIRECT_URI=http://localhost:5000/api/auth/callback

# Discord Bot Token (for bot.py)
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Discord Server/Guild ID (for bot features)
DISCORD_GUILD_ID=your-discord-server-id-here

# ------------------------------------------
# Twitch OAuth (for broadcasting feature)
# ------------------------------------------
# Create Twitch application at: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your-twitch-client-id-here
TWITCH_CLIENT_SECRET=your-twitch-client-secret-here
TWITCH_REDIRECT_URI=http://localhost:5000/api/twitch/callback

# ------------------------------------------
# Email Configuration (for notifications)
# ------------------------------------------
# SMTP settings for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-app-password-here
SMTP_FROM=noreply@sekailink.xyz

# ------------------------------------------
# Application Settings
# ------------------------------------------
# Base URL of your application
BASE_URL=http://localhost:5000

# Domain for cookies
COOKIE_DOMAIN=localhost

# Session timeout in seconds (default: 7 days)
SESSION_LIFETIME=604800

# ------------------------------------------
# File Upload Settings
# ------------------------------------------
# Maximum file size for uploads (in bytes)
# Default: 50MB for ROMs
MAX_UPLOAD_SIZE=52428800

# Upload directories (relative to backend/)
UPLOAD_DIR=static/uploads
ROM_DIR=static/uploads/roms
YAML_DIR=static/uploads/yamls
BOXART_DIR=static/boxarts

# ------------------------------------------
# Security Settings
# ------------------------------------------
# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# Enable CSRF protection
CSRF_ENABLED=True

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000

# ------------------------------------------
# Archipelago Settings
# ------------------------------------------
# Path to Archipelago core installation
ARCHIPELAGO_PATH=./archipelago_core

# Port range for game servers
SERVER_PORT_RANGE_START=38281
SERVER_PORT_RANGE_END=38381

# ------------------------------------------
# Logging Configuration
# ------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file location
LOG_FILE=logs/sekailink.log

# ------------------------------------------
# Maintenance Mode
# ------------------------------------------
# Enable maintenance mode (blocks all non-admin users)
MAINTENANCE_MODE=False

# ------------------------------------------
# Optional: Analytics & Monitoring
# ------------------------------------------
# Sentry DSN for error tracking (optional)
# SENTRY_DSN=your-sentry-dsn-here

# Google Analytics ID (optional)
# GA_TRACKING_ID=UA-XXXXXXXXX-X

# ------------------------------------------
# Development/Testing Only
# ------------------------------------------
# Skip OAuth in development (for testing)
# DEV_SKIP_AUTH=False

# Mock user ID for development
# DEV_MOCK_USER_ID=123456789
