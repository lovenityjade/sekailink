SEKAILINK_ADMIN_HOST=127.0.0.1
SEKAILINK_ADMIN_PORT=19110
SEKAILINK_ADMIN_PUBLIC_BASE_URL=https://admin.sekailink.com
SEKAILINK_ADMIN_DIST_DIR=/opt/sekailink/admin-web/dist
SEKAILINK_ADMIN_DATA_DIR=/srv/nexus-data/admin-web

# Required in production. This is the token entered in the admin web UI.
SEKAILINK_ADMIN_WEB_TOKEN=replace-with-long-random-token

# Internal service locations. Keep these bound to loopback/private networks.
SEKAILINK_IDENTITY_BASE=http://127.0.0.1:19095
SEKAILINK_LOBBY_ADMIN_BASE=http://127.0.0.1:19096
SEKAILINK_CHAT_GATEWAY_BASE=http://127.0.0.1:19098
SEKAILINK_ADMIN_AGENT_BASE=http://127.0.0.1:19091
SEKAILINK_ROOM_SERVER_BASE=http://127.0.0.1:19097

# Internal service tokens. These are never sent to the browser.
SEKAILINK_IDENTITY_ADMIN_TOKEN=replace-identity-admin-token
SEKAILINK_LOBBY_ADMIN_TOKEN=replace-lobby-admin-token
SEKAILINK_CHAT_GATEWAY_TOKEN=replace-chat-gateway-token
SEKAILINK_ADMIN_AGENT_TOKEN=replace-admin-agent-token
SEKAILINK_ROOM_SERVER_ADMIN_TOKEN=replace-room-server-admin-token

# Optional token for clients that submit player conduct reports.
SEKAILINK_USER_REPORT_TOKEN=replace-client-user-report-token
