{
  "preset_id": "alttp.runtime-test.side-by-side",
  "linkedworld_id": "alttp",
  "label": "ALTTP runtime test side by side",
  "status": "canonical-runtime-prep",
  "scope": {
    "covers": "runtime-launch-tracker-and-room-metadata-defaults",
    "omits": "gameplay-option overrides that are already owned by generator presets or seed data"
  },
  "runtime": {
    "presentation_mode": "side-by-side",
    "left_panel": "game",
    "right_panel": "tracker",
    "tracker_variant": "Map Tracker - AP",
    "tracker_pack_path": "tracker/default.zip",
    "yaml_path": "config/default.yaml",
    "tracker_surface_ref": "tracker/default.bundle/surface.complete.json",
    "tracker_flow_ref": "tracker/default.bundle/tracker-flow.v1.json",
    "location_groups_ref": "tracker/location-groups.complete.json",
    "item_slots_ref": "tracker/item-slots.complete.json",
    "room_metadata_ref": "metadata/room-metadata.complete.json",
    "slot_data_ref": "metadata/slot-data.complete.json",
    "bridge_ref": "bridge/sklmi.phase1.json",
    "verbose_log_targets": [
      "sekaiemu",
      "sklmi",
      "link-room"
    ]
  },
  "room_metadata": {
    "required": [
      "seed_id",
      "seed_hash",
      "slot_name",
      "player_alias",
      "tracker_pack",
      "tracker_variant",
      "slot_data"
    ],
    "optional": [
      "goal",
      "mode",
      "entrance_shuffle",
      "item_pool",
      "item_functionality"
    ],
    "slot_data_recommended_visible_fields": [
      "goal",
      "mode",
      "entrance_shuffle",
      "item_pool",
      "item_functionality",
      "glitches_required",
      "dark_room_logic",
      "open_pyramid",
      "big_key_shuffle",
      "small_key_shuffle",
      "key_drop_shuffle",
      "compass_shuffle",
      "map_shuffle",
      "dungeon_counters",
      "boss_shuffle",
      "crystals_needed_for_gt",
      "crystals_needed_for_ganon",
      "progressive",
      "swordless",
      "retro_bow",
      "retro_caves",
      "allow_collect"
    ]
  },
  "notes": [
    "This preset is runtime-facing and does not replace the generator defaults preset.",
    "It exists so the ALTTP module can describe a stable side-by-side test target without forcing the host to guess tracker settings.",
    "The preset now points to repo-owned normalized mappings for location groups, item slots, room metadata, and slot_data display."
  ]
}
