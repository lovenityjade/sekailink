      },
      {
        "zone_id": "ganons_tower",
        "tab_id": "gt",
        "map_id": "turtle_gt"
      }
    ],
    "output_patch": {
      "state_keys": [
        "tracker_state.active_tab_id",
        "tracker_state.active_map_id",
        "tracker_state.autotab_reason",
        "tracker_state.autotab_confidence"
      ],
      "valid_tabs_source": "manifest.json tabs[].id",
      "valid_maps_source": "manifest.json maps[].id"
    }
  },
  "validation_expectations": {
    "json_must_parse": true,
    "all_tab_ids_must_exist_in_manifest": true,
    "all_non_null_map_ids_must_exist_in_manifest": true,
    "all_ref_files_must_exist_in_bundle_or_tracker_root": true,
    "engine_runtime_changes_required": false
  }
}
