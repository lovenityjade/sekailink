  "schema_version": 1,
  "updated": "2026-06-17",
  "purpose": "Archipelago client/APWorld wrappers that SekaiLink can run with its portable Python runtime.",
  "notes": [
    "Generated from SekaiLink Client Core game catalog assets plus local APWorld sources.",
    "The wrapper starts upstream Archipelago client code silently and exposes JSON events to SekaiLink.",
    "Game logic remains in the APWorld/client. SekaiLink does not reimplement item/check memory behavior here.",
    "generator_only entries have an APWorld but no direct memory client wrapper in this pass.",
    "missing_local_apworld entries are kept in excluded until a source is provided."
  ],
