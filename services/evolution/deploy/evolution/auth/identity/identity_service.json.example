{
  "http_port": 19095,
  "sqlite_path": "/opt/sekailink/evolution/auth/data/identity.sqlite3",
  "password_iterations": 120000,
  "password_time_cost": 3,
  "password_memory_kib": 65536,
  "password_parallelism": 1,
  "password_hash_length": 32,
  "password_salt_length": 16,
  "session_ttl_seconds": 2592000,
  "password_reset_ttl_seconds": 1800,
  "public_base_url": "https://sekailink.com",
  "password_reset_path": "/reset-password",
  "email_verification_path": "/verify-email",
  "mail_from": "noreply@sekailink.com",
  "sendmail_path": "/usr/sbin/sendmail",
  "patreon_client_id": "replace-patreon-client-id",
  "patreon_client_secret": "replace-patreon-client-secret",
  "patreon_redirect_uri": "https://sekailink.com/settings/integrations/patreon/callback",
  "patreon_oauth_scopes": "identity identity[email] memberships",
  "patreon_api_version": "2",
  "patreon_creator_access_token": "replace-patreon-creator-access-token",
  "patreon_creator_refresh_token": "replace-patreon-creator-refresh-token"
}
