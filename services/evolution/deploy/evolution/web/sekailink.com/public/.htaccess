<IfModule mod_authz_core.c>
  <FilesMatch "^(WEB_USER_PANEL_AUTH_API|XX-.*)\\.local\\.md$">
    Require all denied
  </FilesMatch>

  <FilesMatch "\\.md$">
    Require all denied
  </FilesMatch>
</IfModule>

<IfModule !mod_authz_core.c>
  <FilesMatch "^(WEB_USER_PANEL_AUTH_API|XX-.*)\\.local\\.md$">
    Order allow,deny
    Deny from all
  </FilesMatch>

  <FilesMatch "\\.md$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>
