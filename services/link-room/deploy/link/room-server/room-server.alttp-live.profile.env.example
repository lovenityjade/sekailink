# Operator profile for the first ALTTP live room test on the link host.
# This file is not consumed directly by sekailink_room_server_service.
# It captures the target host, the loopback runtime surface, and the public
# edge values testers should receive.

SEKAILINK_LINK_HOST=link.sekailink.com
SEKAILINK_LINK_ROOM_ROOT=/opt/sekailink/link/room-server
SEKAILINK_LINK_ROOM_SERVICE=sekailink-room-server.service
SEKAILINK_LINK_ROOM_ENV=/opt/sekailink/link/room-server/config/room_server.env
SEKAILINK_LINK_ROOM_LOG=
SEKAILINK_LINK_ROOM_STATE=/opt/sekailink/link/room-server/runtime/room_server_state.json
SEKAILINK_LINK_ROOM_PROJECTION_BACKEND=mysql
SEKAILINK_LINK_ROOM_PROJECTION_TARGET=sekailink_room_projection
SEKAILINK_NEXUS_ROOM_QUERY_UNIT=sekailink-nexus-room-query.service
SEKAILINK_NEXUS_ROOM_QUERY_HTTP_BASE_URL=http://149.202.61.90:19094

SEKAILINK_LINK_ROOM_LOOPBACK_TCP_HOST=127.0.0.1
SEKAILINK_LINK_ROOM_LOOPBACK_TCP_PORT=18080
SEKAILINK_LINK_ROOM_LOOPBACK_HTTP_HOST=127.0.0.1
SEKAILINK_LINK_ROOM_LOOPBACK_HTTP_PORT=18081

# Fill these with the edge or tunnel values actually shared with external testers.
SEKAILINK_LINK_ROOM_PUBLIC_TCP_HOST=replace-public-tcp-host
SEKAILINK_LINK_ROOM_PUBLIC_TCP_PORT=replace-public-tcp-port
SEKAILINK_LINK_ROOM_PUBLIC_HTTP_BASE_URL=https://replace-public-http-host

SEKAILINK_ALTTP_TEST_ROOM_ID=alttp-live-1
SEKAILINK_ALTTP_TEST_ROOM_TYPE=live
SEKAILINK_ALTTP_TEST_GAME="A Link to the Past"
SEKAILINK_ALTTP_TEST_TEAM_ID=0
SEKAILINK_ALTTP_TEST_SLOT_ID=1
SEKAILINK_ALTTP_TEST_SLOT_NAME=Link
SEKAILINK_ALTTP_TEST_SLOT_ALIAS="ALTTP Link"
SEKAILINK_ALTTP_TEST_SEED_NAME=alttp-live-seed-1
SEKAILINK_ALTTP_TEST_SEED_ID=seed-live-1
SEKAILINK_ALTTP_TEST_SEED_HASH="BOW-MOON-MAP"
SEKAILINK_ALTTP_TEST_TRACKER_PACK=alttp-pack
SEKAILINK_ALTTP_TEST_TRACKER_VARIANT="Map Tracker - AP"

# First runtime settings pushed through set_slot_data during smoke.
SEKAILINK_ALTTP_TEST_GOAL=ganon
SEKAILINK_ALTTP_TEST_MODE=open
SEKAILINK_ALTTP_TEST_DIFFICULTY=normal
SEKAILINK_ALTTP_TEST_WEAPONS=randomized
