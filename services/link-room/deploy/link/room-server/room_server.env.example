# Keep live secrets here instead of in room_server.json.
# This underscore-named file matches the active live service layout on link.
# Generate each token independently, for example:
#   openssl rand -hex 24
# Only the variables below are consumed by the room server runtime.
SEKAILINK_ROOM_SERVER_ADMIN_TOKEN=replace-admin-token
SEKAILINK_ROOM_SERVER_RUNTIME_TOKEN=replace-runtime-token
SEKAILINK_ROOM_SERVER_CLIENT_REPORT_TOKEN=replace-client-report-token

# Needed when projection_backend is mysql and the projection target is shared
# with Nexus room-query.
SEKAILINK_MYSQL_HOST=replace-nexus-mysql-host
SEKAILINK_MYSQL_PORT=3306
SEKAILINK_MYSQL_USER=replace-nexus-mysql-user
SEKAILINK_MYSQL_PASSWORD=replace-nexus-mysql-password
# SEKAILINK_MYSQL_SOCKET=
