SKLMI_ROOM_HOST=link.sekailink.com

# If the private room uses one shared TCP endpoint, set SKLMI_ROOM_PORT and
# leave the split ports unset.
# SKLMI_ROOM_PORT=28080

# If the private room exposes separate control/runtime endpoints, set them
# explicitly.
SKLMI_ROOM_CONTROL_PORT=28080
SKLMI_ROOM_RUNTIME_PORT=28081

SKLMI_ROOM_CONTROL_CHANNEL=core
SKLMI_ROOM_SESSION_NAME=replace-me
SKLMI_ROOM_SLOT_ID=1

# Ticket issuance path:
# SKLMI_ROOM_CONTROL_AUTH_TOKEN=replace-me

# Runtime path:
# SKLMI_ROOM_RUNTIME_AUTH_TOKEN=replace-me

# If a runtime session token is pre-issued, SKLMI can skip issue_ticket and only
# use the runtime port.
# SKLMI_ROOM_RUNTIME_SESSION_TOKEN=replace-me

SKLMI_TICK_MS=16
SKLMI_MAX_TICKS=5
