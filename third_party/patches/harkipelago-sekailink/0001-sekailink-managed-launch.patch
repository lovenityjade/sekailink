+namespace {
+struct SekaiLinkLaunchOptions {
+    std::optional<std::filesystem::path> manifestPath;
+    std::vector<char*> passthroughArgs;
+};
+
+SekaiLinkLaunchOptions ParseSekaiLinkLaunchOptions(int argc, char* argv[]) {
+    SekaiLinkLaunchOptions result;
+    result.passthroughArgs.reserve(argc);
+    result.passthroughArgs.push_back(argv[0]);
+
+    for (int i = 1; i < argc; ++i) {
+        const std::string_view argument(argv[i]);
+        if (argument == "--sekailink-launch") {
+            if (++i >= argc) {
+                throw std::runtime_error("--sekailink-launch requires a manifest path");
+            }
+            result.manifestPath = std::filesystem::path(argv[i]);
+            continue;
+        }
+        result.passthroughArgs.push_back(argv[i]);
+    }
+    return result;
+}
+
+void ApplySekaiLinkLaunchManifest(const std::filesystem::path& manifestPath) {
+    std::ifstream input(manifestPath);
+    if (!input) {
+        throw std::runtime_error("Unable to open SekaiLink launch manifest: " + manifestPath.string());
+    }
+
+    const nlohmann::json manifest = nlohmann::json::parse(input);
+    if (manifest.value("schema", "") != "sekailink.pc-launch/v1" ||
+        manifest.value("gameId", "") != "ship-of-harkinian") {
+        throw std::runtime_error("Unsupported SekaiLink launch manifest");
+    }
+
+    const auto connection = manifest.at("connection");
+    const std::string server = connection.at("server").get<std::string>();
+    const std::string slot = connection.at("slot").get<std::string>();
+    const std::string password = connection.value("password", "");
+    if (server.empty() || slot.empty()) {
+        throw std::runtime_error("SekaiLink launch manifest requires connection.server and connection.slot");
+    }
+
+    CVarSetString(CVAR_REMOTE_ARCHIPELAGO("ServerAddress"), server.c_str());
+    CVarSetString(CVAR_REMOTE_ARCHIPELAGO("SlotName"), slot.c_str());
+    CVarSetString(CVAR_REMOTE_ARCHIPELAGO("Password"), password.c_str());
+    CVarSetInteger(CVAR_REMOTE_ARCHIPELAGO("SekaiLinkManaged"), 1);
+    CVarSetInteger(CVAR_REMOTE_ARCHIPELAGO("SekaiLinkAutoConnect"), connection.value("autoConnect", true));
+}
+} // namespace
