{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Setup CMake Project",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build-cmake",
                "-G",
                "Ninja"
            ],
            "windows": {
                "command": "${env:ProgramFiles}\\CMake\\bin\\cmake.exe",
                "args": [
                    "-S",
                    ".",
                    "-B",
                    "build/x64",
                    "-G",
                    "Visual Studio 17 2022",
                    "-T",
                    "v143",
                    "-A",
                    "x64",
                    "-DBUILD_REMOTE_CONTROL=ON"
                ],
                "options": {
                    "env": {
                        "Path": "C:\\Program Files\\Git\\cmd;${env:Path}"
                    },
                    "shell": {
                        "executable": "C:\\Windows\\System32\\cmd.exe",
                        "args": ["/d", "/c"]
                    }
                }
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Generate SOH OTR",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build-cmake",
                "--target",
                "GenerateSohOtr",
                "--parallel"
            ],
            "windows": {
                "command": "${env:ProgramFiles}\\CMake\\bin\\cmake.exe",
                "args": [
                    "--build",
                    "build/x64",
                    "--target",
                    "GenerateSohOtr",
                    "--config",
                    "Release",
                    "--parallel"
                ],
                "options": {
                    "env": {
                        "Path": "C:\\Program Files\\Git\\cmd;${env:Path}"
                    },
                    "shell": {
                        "executable": "C:\\Windows\\System32\\cmd.exe",
                        "args": ["/d", "/c"]
                    }
                }
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build soh (incremental)",
